{
  "name": "damagochat",
  "version": "1.0.0",
  "description": "Damagochat — production-grade real-time messaging backend",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "start:cluster": "pm2 start dist/main.js -i max",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit --reporter=verbose",
    "test:integration": "vitest run tests/integration --reporter=verbose",
    "test:e2e": "vitest run tests/e2e --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.49.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
    "@opentelemetry/sdk-metrics": "^1.25.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/semantic-conventions": "^1.25.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "@prisma/client": "^5.14.0",
    "@signalapp/libsignal-client": "^0.54.0",
    "bullmq": "^5.8.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^4.5.1",
    "firebase-admin": "^12.2.0",
    "ioredis": "^5.3.2",
    "meilisearch": "^0.40.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "sharp": "^0.33.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "prisma": "^5.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "testcontainers": "^10.10.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
