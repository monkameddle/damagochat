# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://damagochat:damagochat@localhost:5432/damagochat

# Redis
REDIS_URL=redis://localhost:6379

# JWT  (generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=change_me_to_a_random_64_char_string_in_production_00000000000000
JWT_REFRESH_SECRET=change_me_to_a_different_random_64_char_string_in_prod_00000000
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Hetzner Object Storage (S3-compatible)
# Dev: use MinIO via docker compose (values below work out of the box)
# Prod: replace with Hetzner Object Storage endpoint + credentials
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=damagochat-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=fsn1
S3_FORCE_PATH_STYLE=true   # true for MinIO, false for Hetzner Object Storage

# Media
MEDIA_MAX_SIZE_MB=64

# SMS via seven.io  (https://www.seven.io)
# Dev: OTP_STUB=true skips SMS entirely (any 6-digit code accepted)
OTP_STUB=true
SEVEN_API_KEY=
SEVEN_FROM=Damagochat

# Push notifications — pick ONE, leave others blank
#
# Option A: ntfy — self-hosted, no Google, works on sideloaded + de-Googled devices
#   Add ntfy to docker-compose, device subscribes to topic "damagochat-{userId}"
NTFY_URL=
NTFY_TOKEN=
#
# Option B: OneSignal — free tier, requires Google Play Services on device
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
#
# Option C: Firebase FCM direct — requires Google account
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=masterKey

# OpenTelemetry (optional — set OTEL_DISABLED=true to skip)
OTEL_DISABLED=true
OTEL_SERVICE_NAME=damagochat
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
